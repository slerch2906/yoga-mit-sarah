# ============================================================
# Yoga mit Sarah – E2E Test-Konfiguration
# Diese Datei als .env.test speichern und Werte eintragen
# ============================================================

# URL der App die getestet wird
# Live:   BASE_URL=https://kurse.yogamitsarah.me
# Lokal:  BASE_URL=http://localhost:3000
BASE_URL=https://kurse.yogamitsarah.me

# Supabase – PRODUCTION oder TEST-Projekt
# Empfehlung: Zweites Supabase-Projekt für Tests anlegen
SUPABASE_URL=https://DEIN_PROJEKT.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...   # NUR für Test-Setup, NICHT in der App!

# Test-Accounts (werden von npm run test:setup erstellt)
TEST_ADMIN_EMAIL=e2e.admin@yogamitsarah.me
TEST_ADMIN_PASSWORD=E2eAdmin2026!
TEST_YOGI1_EMAIL=e2e.yogi1@yogamitsarah.me
TEST_YOGI1_PASSWORD=E2eYogi12026!
TEST_YOGI2_EMAIL=e2e.yogi2@yogamitsarah.me
TEST_YOGI2_PASSWORD=E2eYogi22026!

# Mailtrap – kostenlose Test-Emails prüfen
# Registrierung: https://mailtrap.io (kostenlos)
# API-Token: mailtrap.io → API → API Tokens
MAILTRAP_API_TOKEN=dein_token_hier
MAILTRAP_INBOX_ID=123456

# ============================================================
# WICHTIG: .env.test niemals in Git committen!
# In .gitignore eingetragen: .env.test
# ============================================================
